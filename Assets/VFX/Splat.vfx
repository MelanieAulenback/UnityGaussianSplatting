  m_OutputSlots:
  - {fileID: 8926484042661616581}
  - {fileID: 8926484042661616585}
  m_OperatorName: Select Axes
  m_HLSLCode: "void SelectAxes(in float3 X, in float3 Y, in float3 Z, out float3
    x, out float3 y)\r\n{\r\n    float3 viewX = TransformWorldToViewDir(X);\r\n   
    float3 viewY = TransformWorldToViewDir(Y);\r\n    float3 viewZ = TransformWorldToViewDir(Z);\r\n\r\n\tfloat
    areaXY = abs(viewX.x * viewY.y - viewX.y * viewY.x);\r\n\tfloat areaYZ = abs(viewY.x
    * viewZ.y - viewY.y * viewZ.x);\r\n\tfloat areaXZ = abs(viewX.x * viewZ.y - viewX.y
    * viewZ.x);\t\r\n\r\n\tfloat xyMask = step(areaYZ, areaXY) * step(areaXZ, areaXY);\r\n\tfloat
    yzMask = step(areaXY, areaYZ) * step(areaXZ, areaYZ);\r\n    float xzMask = step(areaXY,
    areaXZ) * step(areaYZ, areaXZ);\r\n\r\n\tx = xyMask * X + yzMask * Y + xzMask
    * X;\r\n\ty = xyMask * Y + yzMask * Z + xzMask * Z;\r\n}\r\n"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunctions:
    selection: SelectAxes
    selectedIndex: 0
